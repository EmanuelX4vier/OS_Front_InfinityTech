<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0"
            styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.EstoqueController">

    <children>
        <VBox spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">

            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="GESTÃO DE ESTOQUE">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Text>
                                <Text fill="#d4af37" strokeType="OUTSIDE" strokeWidth="0.0" text="Infinity Tech - Controle de Produtos">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Text>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="15.0" alignment="CENTER">
                            <children>
                                <Button onAction="#handleAtualizar" prefHeight="40.0" prefWidth="130.0"
                                        styleClass="login-button" style="-fx-background-color: #555555;" text="ATUALIZAR" />
                                <Button onAction="#handleAdicionar" prefHeight="40.0" prefWidth="130.0"
                                        styleClass="login-button" text="ADICIONAR" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblEstoque" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colCodigo" prefWidth="80.0" text="CÓDIGO" />
                        <TableColumn fx:id="colNome" prefWidth="200.0" text="NOME DO PRODUTO" />
                        <TableColumn fx:id="colMarca" prefWidth="120.0" text="MARCA" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="STATUS" />
                        <TableColumn fx:id="colQuantidade" prefWidth="80.0" text="QTD" />
                        <TableColumn fx:id="colValorCompra" prefWidth="120.0" text="VALOR COMPRA" />
                        <TableColumn fx:id="colValorVenda" prefWidth="120.0" text="VALOR VENDA" />

                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button mnemonicParsing="false"
                                onAction="#handleVoltar"
                                prefHeight="40.0"
                                prefWidth="180.0"
                                styleClass="login-button"
                                text="VOLTAR À HOME" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>