<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="850.0"
            styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.EstoqueController">

    <children>
        <VBox spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">

            <children>
                <VBox spacing="8.0">
                    <children>
                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="ESTOQUE DE PRODUTOS">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Text>
                        <Line endX="280.0" stroke="#d4af37" strokeWidth="1.0" />
                        <Text fill="#d4af37" text="• CONSULTA DE INVENTÁRIO •">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Text>
                    </children>
                </VBox>

                <TableView fx:id="tblEstoque" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colCodigo" prefWidth="120.0" text="CÓDIGO" />
                        <TableColumn fx:id="colNome" prefWidth="280.0" text="NOME DO PRODUTO" />
                        <TableColumn fx:id="colMarca" prefWidth="180.0" text="MARCA" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="STATUS" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button mnemonicParsing="false"
                                onAction="#handleVoltar"
                                prefHeight="40.0"
                                prefWidth="150.0"
                                styleClass="login-button"
                                text="VOLTAR À HOME" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>