<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="620.0"
            prefWidth="720.0"
            styleClass="main-background"
            stylesheets="@../../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.dialog.DialogServiceController">

    <children>

        <VBox spacing="25.0"
              AnchorPane.topAnchor="30.0"
              AnchorPane.bottomAnchor="30.0"
              AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0">

            <children>

                <VBox spacing="8.0">

                    <children>

                        <Text text="NOVA ORDEM"
                              fill="WHITE">

                            <font>
                                <Font name="System Bold"
                                      size="24.0"/>
                            </font>
                        </Text>

                        <Text text="Infinity Tech - Cadastro de Ordem"
                              fill="#d4af37">

                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Text>

                    </children>
                </VBox>

                <GridPane hgap="20.0"
                          vgap="18.0">

                    <padding>
                        <Insets top="10"
                                right="10"
                                bottom="10"
                                left="10"/>
                    </padding>

                    <columnConstraints>

                        <ColumnConstraints percentWidth="30"/>

                        <ColumnConstraints percentWidth="70"/>

                    </columnConstraints>

                    <children>

                        <!-- SERIAL -->

                        <Label text="Serial:"
                               textFill="WHITE"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="0"/>

                        <TextField fx:id="txtSerial"
                                   promptText="Digite o serial do equipamento"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>

                        <!-- CLIENT ID -->

                        <Label text="Client ID:"
                               textFill="WHITE"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="1"/>

                        <TextField fx:id="txtClientId"
                                   promptText="Digite o ID do client"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>

                        <!-- CLIENT NOME -->

                        <Label text="Client:"
                               textFill="WHITE"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="2"/>

                        <TextField fx:id="txtClientNome"
                                   editable="true"
                                   promptText="Nome do client"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="2"/>

                        <!-- STATUS -->

                        <Label text="Status:"
                               textFill="WHITE"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="3"/>

                        <ComboBox fx:id="cbStatus"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="3"/>

                        <!-- DESCRIÇÃO -->

                        <Label text="Descrição:"
                               textFill="WHITE"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="4"/>

                        <TextArea fx:id="txtDescricao"
                                  prefHeight="220"
                                  wrapText="true"
                                  promptText="Digite a descrição do equipamento/problema"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="4"/>

                    </children>
                </GridPane>

                <!-- MENSAGEM -->

                <Label fx:id="lblMensagem"
                       textFill="WHITE"/>

                <!-- BOTÕES -->

                <HBox spacing="15.0"
                      alignment="CENTER_RIGHT">

                    <children>

                        <Button text="CANCELAR"
                                onAction="#handleCancelar"
                                prefWidth="120"
                                prefHeight="40"
                                styleClass="login-button"
                                style="-fx-background-color: #555555;"/>

                        <Button text="SALVAR"
                                onAction="#handleSalvar"
                                prefWidth="120"
                                prefHeight="40"
                                styleClass="login-button"/>

                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>