<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20.0"
      styleClass="dialog-background, dialog-border"
      stylesheets="@../../css/style.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="os.infinitytech.os_front_infinitytech.controller.dialog.DialogStockController">

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <children>
        <VBox spacing="2.0">
            <children>
                <Text text="NOVO PRODUTO" styleClass="dashboard-title" style="-fx-font-size: 20px; -fx-letter-spacing: 2px;" />
                <Text text="INFINITY TECH - CADASTRO DE ESTOQUE" styleClass="dashboard-subtitle" style="-fx-font-size: 11px; -fx-letter-spacing: 1px;" />
            </children>
        </VBox>

        <GridPane hgap="15.0" vgap="12.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="35"/>
                <ColumnConstraints percentWidth="65"/>
            </columnConstraints>
            <children>
                <Label text="CÓDIGO:" textFill="#FFD700" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                <TextField fx:id="txtCodigo" promptText="Ex: 001" styleClass="cyber-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="NOME:" textFill="#FFD700" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                <TextField fx:id="txtNome" promptText="Nome do produto" styleClass="cyber-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="MARCA:" textFill="#FFD700" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                <TextField fx:id="txtMarca" promptText="Marca" styleClass="cyber-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="STATUS:" textFill="#FFD700" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
                <ComboBox fx:id="cbStatus" prefWidth="Infinity" promptText="Selecione..." styleClass="cyber-input" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="QTD:" textFill="#FFD700" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;" />
                <TextField fx:id="txtQuantidade" promptText="0" styleClass="cyber-input" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="V. COMPRA:" textFill="#FFD700" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold;" />
                <TextField fx:id="txtValorCompra" promptText="0.00" styleClass="cyber-input" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label text="V. VENDA:" textFill="#FFD700" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold;" />
                <TextField fx:id="txtValorVenda" promptText="0.00" styleClass="cyber-input" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button onAction="#handleCancelar" text="CANCELAR"
                        styleClass="module-button"
                        style="-fx-pref-width: 120px; -fx-background-color: rgba(85,85,85,0.5);" />
                <Button onAction="#handleSalvar" text="SALVAR"
                        styleClass="module-button"
                        style="-fx-pref-width: 120px;" />
            </children>
        </HBox>
    </children>
</VBox>