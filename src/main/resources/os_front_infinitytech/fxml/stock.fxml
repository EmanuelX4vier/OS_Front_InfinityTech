<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0"
            styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.StockController">

    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="25.0"
              AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="25.0">

            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Text text="GESTÃO DE ESTOQUE" styleClass="dashboard-title" style="-fx-font-size: 24px; -fx-letter-spacing: 4px;" />
                                <Text text="INFINITY TECH - MÓDULO ESTOQUE" styleClass="dashboard-subtitle" style="-fx-font-size: 10px; -fx-letter-spacing: 2px;" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <TextField fx:id="txtPesquisa" promptText="Buscar produto..."
                                   styleClass="cyber-input" prefHeight="40.0" prefWidth="250.0" />

                        <Button onAction="#handleAtualizar" text="🔄"
                                styleClass="module-button, btn-square" />

                        <Button onAction="#handleAdicionar" text="+"
                                styleClass="module-button, btn-square" />
                    </children>
                </HBox>

                <TableView fx:id="tblEstoque" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colCodigo" prefWidth="100.0" text="CÓDIGO" />
                        <TableColumn fx:id="colNome" prefWidth="250.0" text="NOME DO PRODUTO" />
                        <TableColumn fx:id="colMarca" prefWidth="120.0" text="MARCA" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="STATUS" />
                        <TableColumn fx:id="colQuantidade" prefWidth="80.0" text="QTD" />
                        <TableColumn fx:id="colValorCompra" prefWidth="120.0" text="VALOR COMPRA" />
                        <TableColumn fx:id="colValorVenda" prefWidth="120.0" text="VALOR VENDA" styleClass="last-col" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="btnPaginaAnterior" text="◀"
                                onAction="#handlePaginaAnterior"
                                styleClass="module-button, btn-square" />

                        <Label fx:id="lblPaginaAtual" text="Página: 1"
                               styleClass="dashboard-subtitle" style="-fx-text-fill: white; -fx-font-size: 14px;"/>

                        <Button fx:id="btnProximaPagina" text="▶"
                                onAction="#handleProximaPagina"
                                styleClass="module-button, btn-square" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button onAction="#handleVoltar" text="VOLTAR"
                                styleClass="module-button"
                                style="-fx-pref-width: 180px; -fx-background-color: rgba(85,85,85,0.5);" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>