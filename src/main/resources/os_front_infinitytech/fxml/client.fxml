<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="1200.0"
            styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.ClientController">

    <children>
        <VBox spacing="25.0"
              AnchorPane.topAnchor="30.0"
              AnchorPane.bottomAnchor="30.0"
              AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0">

            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Text text="GESTÃO DE CLIENTES" fill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="24.0"/>
                                    </font>
                                </Text>
                                <Text text="Infinity Tech - Controle de Clientes" fill="#d4af37">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Text>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox spacing="15.0" alignment="CENTER">
                            <children>
                                <Button text="ATUALIZAR"
                                        onAction="#handleAtualizar"
                                        prefWidth="130" prefHeight="40"
                                        styleClass="login-button"
                                        style="-fx-background-color: #555555;" />

                                <Button text="ADICIONAR"
                                        onAction="#handleAdicionar"
                                        prefWidth="130" prefHeight="40"
                                        styleClass="login-button" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblClients" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80" />
                        <TableColumn fx:id="colNome" text="NOME" prefWidth="300" />
                        <TableColumn fx:id="colTelefone" text="TELEFONE" prefWidth="180" />
                        <TableColumn fx:id="colEndereco" text="ENDEREÇO" prefWidth="400" />
                        <TableColumn fx:id="colDataCadastro" text="DATA CADASTRO" prefWidth="180" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="20.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnClientAnterior"
                                text="◀ ANTERIOR"
                                onAction="#handleClientAnterior"
                                styleClass="login-button"
                                style="-fx-background-color: #555555;"
                                prefWidth="130" prefHeight="35"/>

                        <Label fx:id="lblClientPagina"
                               text="Página: 1"
                               textFill="WHITE"
                               style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                        <Button fx:id="btnClientProxima"
                                text="PRÓXIMA ▶"
                                onAction="#handleClientProxima"
                                styleClass="login-button"
                                prefWidth="130" prefHeight="35"/>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button text="VOLTAR"
                                onAction="#handleVoltar"
                                prefWidth="130" prefHeight="40"
                                styleClass="login-button"
                                style="-fx-background-color: #555555;" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>