<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="1200.0"
            styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.ClientController">

    <children>
        <VBox spacing="25.0"
              AnchorPane.topAnchor="30.0"
              AnchorPane.bottomAnchor="30.0"
              AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0">

            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Text text="GESTÃO DE CLIENTES" styleClass="dashboard-title" style="-fx-font-size: 24px; -fx-letter-spacing: 4px;" />
                                <Text text="INFINITY TECH - CONTROLE DE CLIENTES" styleClass="dashboard-subtitle" style="-fx-font-size: 10px; -fx-letter-spacing: 2px;" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox spacing="15.0" alignment="CENTER">
                            <children>
                                <Button text="🔄"
                                        onAction="#handleAtualizar"
                                        styleClass="module-button, btn-square"
                                />

                                <Button text="+"
                                        onAction="#handleAdicionar"
                                        styleClass="module-button, btn-square"
                                />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblClients" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80" />
                        <TableColumn fx:id="colNome" text="NOME" prefWidth="300" />
                        <TableColumn fx:id="colTelefone" text="TELEFONE" prefWidth="180" />
                        <TableColumn fx:id="colEndereco" text="ENDEREÇO" prefWidth="400" />
                        <TableColumn fx:id="colDataCadastro" text="DATA CADASTRO" prefWidth="180" styleClass="last-col" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="20.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnClientAnterior" text="◀"
                                onAction="#handleClientAnterior"
                                styleClass="module-button"
                                style="-fx-pref-width: 150px; -fx-background-color: rgba(85,85,85,0.5);" />

                        <Label fx:id="lblClientPagina" text="Página: 1" styleClass="dashboard-subtitle" style="-fx-font-size: 14px; -fx-fill: white;" />

                        <Button fx:id="btnClientProxima" text="▶"
                                onAction="#handleClientProxima"
                                styleClass="module-button"
                                style="-fx-pref-width: 150px;" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button text="VOLTAR"
                                onAction="#handleVoltar"
                                styleClass="module-button"
                                style="-fx-pref-width: 150px; -fx-background-color: rgba(85,85,85,0.5);" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>