<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" style="-fx-background-color: #0F0F0F;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="os.infinitytech.os_front_infinitytech.controller.HelloController">

    <children>
        <VBox alignment="CENTER" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="INFINITY TECH">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Text>
                        <Line endX="120.0" stroke="#d4af37" strokeWidth="0.5" />
                        <Text fill="#d4af37" strokeType="OUTSIDE" strokeWidth="0.0" text="• LOGIN DO SISTEMA •">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Text>
                    </children>
                </VBox>

                <VBox alignment="CENTER" maxWidth="380.0" spacing="15.0">
                    <children>
                        <TextField promptText="NOME DE USUÁRIO" styleClass="login-input" />

                        <PasswordField promptText="SENHA" styleClass="login-input" />

                        <Button maxWidth="Infinity" mnemonicParsing="false" prefHeight="45.0" styleClass="login-button" text="ENTRAR" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Hyperlink styleClass="forgot-link" text="Esqueceu a senha?" />
                        <Hyperlink styleClass="forgot-link" text="Criar uma conta" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
