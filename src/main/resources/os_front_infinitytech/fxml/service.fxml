<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="1200.0" styleClass="main-background" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="os.infinitytech.os_front_infinitytech.controller.ServiceController">

    <children>
        <VBox spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">

            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Text style="-fx-font-size: 24px; -fx-letter-spacing: 4px;" styleClass="dashboard-title" text="GESTÃO DE ORDENS DE SERVIÇO" />
                                <Text style="-fx-font-size: 10px; -fx-letter-spacing: 2px;" styleClass="dashboard-subtitle" text="INFINITY TECH - CONTROLE DE SERVIÇOS" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button onAction="#handleAtualizar" styleClass="module-button, btn-square" text="🔄" />

                                <Button onAction="#handleAdicionar" styleClass="module-button, btn-square" text="+" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblOrdens" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colClientId" prefWidth="100" text="ID CLIENTE" />
                        <TableColumn fx:id="colClient" prefWidth="250" text="NOME DO CLIENTE" />
                        <TableColumn fx:id="colSerial" prefWidth="180" text="Nº SÉRIE / EQUIP." />
                        <TableColumn fx:id="colDescricao" prefWidth="350" text="DESCRIÇÃO DO SERVIÇO" />
                        <TableColumn fx:id="colStatus" prefWidth="140" text="STATUS" />
                        <TableColumn fx:id="colDataCadastro" prefWidth="150" styleClass="last-col" text="DATA CADASTRO" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="btnOrdemAnterior" onAction="#handleOrdemAnterior" styleClass="module-button, btn-square" text="◀" />

                        <Label fx:id="lblOrdemPagina" style="-fx-font-size: 14px; -fx-fill: white;" styleClass="dashboard-subtitle" text="Página: 1" />

                        <Button fx:id="btnOrdemProxima" onAction="#handleOrdemProxima" styleClass="module-button, btn-square" text="▶" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button onAction="#handleVoltar" style="-fx-pref-width: 180px; -fx-background-color: rgba(85,85,85,0.5);" styleClass="module-button" text="VOLTAR" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
