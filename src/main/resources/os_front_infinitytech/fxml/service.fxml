<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="1200.0"
            styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.ServiceController">

    <children>
        <VBox spacing="25.0"
              AnchorPane.topAnchor="30.0"
              AnchorPane.bottomAnchor="30.0"
              AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0">

            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Text text="GESTÃO DE ORDENS DE SERVIÇO" styleClass="dashboard-title" style="-fx-font-size: 24px; -fx-letter-spacing: 4px;" />
                                <Text text="INFINITY TECH - CONTROLE DE SERVIÇOS" styleClass="dashboard-subtitle" style="-fx-font-size: 10px; -fx-letter-spacing: 2px;" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox spacing="15.0" alignment="CENTER">
                            <children>
                                <Button text="🔄"
                                        onAction="#handleAtualizar"
                                        styleClass="module-button, btn-square"
                                />

                                <Button text="+"
                                        onAction="#handleAdicionar"
                                        styleClass="module-button, btn-square"
                                />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblOrdens" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colClientId" text="ID CLIENTE" prefWidth="100" />
                        <TableColumn fx:id="colClient" text="NOME DO CLIENTE" prefWidth="250" />
                        <TableColumn fx:id="colSerial" text="Nº SÉRIE / EQUIP." prefWidth="180" />
                        <TableColumn fx:id="colDescricao" text="DESCRIÇÃO DO SERVIÇO" prefWidth="350" />
                        <TableColumn fx:id="colStatus" text="STATUS" prefWidth="140" />
                        <TableColumn fx:id="colDataCadastro" text="DATA CADASTRO" prefWidth="150" styleClass="last-col" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="20.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnOrdemAnterior"
                                text="◀ ANTERIOR"
                                onAction="#handleOrdemAnterior"
                                styleClass="module-button"
                                style="-fx-pref-width: 150px; -fx-background-color: rgba(85,85,85,0.5);" />

                        <Label fx:id="lblOrdemPagina"
                               text="Página: 1"
                               styleClass="dashboard-subtitle"
                               style="-fx-font-size: 14px; -fx-fill: white;" />

                        <Button fx:id="btnOrdemProxima"
                                text="PRÓXIMA ▶"
                                onAction="#handleOrdemProxima"
                                styleClass="module-button"
                                style="-fx-pref-width: 150px;" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button text="VOLTAR À HOME"
                                onAction="#handleVoltar"
                                styleClass="module-button"
                                style="-fx-pref-width: 180px; -fx-background-color: rgba(85,85,85,0.5);" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>