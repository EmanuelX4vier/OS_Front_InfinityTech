<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="rootPane"
            prefHeight="600.0"
            prefWidth="850.0"
            styleClass="main-background"
            stylesheets="@../../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.initial.LoginController">

    <children>
        <VBox alignment="CENTER"
              spacing="30.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <children>

                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Text fill="WHITE" text="INFINITY TECH">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Text>

                        <Line endX="120.0" stroke="#d4af37" strokeWidth="0.5" />

                        <Text fill="#d4af37" text="• LOGIN DO SISTEMA •">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Text>
                    </children>
                </VBox>

                <VBox alignment="CENTER" maxWidth="380.0" spacing="15.0">
                    <children>
                        <TextField fx:id="emailField"
                                   promptText="NOME DE USUÁRIO"
                                   styleClass="login-input" />

                        <PasswordField fx:id="passwordField"
                                       promptText="SENHA"
                                       styleClass="login-input" />

                        <Button maxWidth="Infinity"
                                onAction="#onLogin"
                                prefHeight="45.0"
                                styleClass="login-button"
                                text="ENTRAR"
                                defaultButton="true" />
                    </children>
                </VBox>

                <!-- MENSAGEM -->
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label fx:id="lblMensagem"
                               text=""
                               style="-fx-text-fill: white; -fx-font-size: 12px;" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>