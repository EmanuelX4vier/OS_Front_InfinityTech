<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="rootPane"
            prefHeight="600.0"
            prefWidth="850.0"
            styleClass="main-background"
            stylesheets="@../../css/style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.initial.LoginController">

    <children>
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <VBox alignment="CENTER" maxWidth="350" maxHeight="400"
                  style="-fx-background-color: rgba(0,0,0,0.9); -fx-border-color: rgba(255,215,0,0.3); -fx-border-width: 1; -fx-padding: 30;">

                <children>
                    <Text text="INFINITY TECH" styleClass="dashboard-title" style="-fx-font-size: 32px;" />
                    <Text text="SISTEMA DE INVENTÁRIO" styleClass="dashboard-subtitle" />

                    <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                        <children>
                            <VBox spacing="5">
                                <Label text="USUÁRIO" style="-fx-text-fill: rgba(255,215,0,0.6); -fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-letter-spacing: 2px;"/>
                                <TextField fx:id="emailField" promptText="Digite seu usuário" styleClass="cyber-input" prefHeight="35"/>
                            </VBox>

                            <VBox spacing="5">
                                <Label text="SENHA" style="-fx-text-fill: rgba(255,215,0,0.6); -fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-letter-spacing: 2px;"/>
                                <PasswordField fx:id="passwordField" promptText="........" styleClass="cyber-input" prefHeight="35"/>
                            </VBox>

                            <Button maxWidth="Infinity" onAction="#onLogin" prefHeight="40.0"
                                    styleClass="module-button" text="ENTRAR" />
                        </children>
                    </VBox>

                    <Label fx:id="lblMensagem" text="" style="-fx-text-fill: #FFD700; -fx-padding: 15 0 0 0;"/>
                </children>
            </VBox>
        </StackPane>
    </children>
</AnchorPane>