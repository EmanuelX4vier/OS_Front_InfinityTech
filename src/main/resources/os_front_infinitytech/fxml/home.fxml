<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<AnchorPane fx:id="rootPane"
            prefHeight="600.0"
            prefWidth="850.0"
            styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="os.infinitytech.os_front_infinitytech.controller.HomeController">

    <children>
        <!-- Alterado o alinhamento para TOP_CENTER para empurrar o conteúdo para cima -->
        <VBox alignment="TOP_CENTER"
              spacing="60.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <padding>
                <Insets top="80.0" /> <!-- Define a distância do topo -->
            </padding>

            <children>
                <!-- Cabeçalho -->
                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="INFINITY TECH">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Text>
                        <Line endX="120.0" stroke="#d4af37" strokeWidth="0.5" />
                        <Text fill="#d4af37" strokeType="OUTSIDE" strokeWidth="0.0" text="• PAINEL PRINCIPAL •">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Text>
                    </children>
                </VBox>

                <!-- Container dos botões: Trocado de HBox para VBox para ficarem um acima do outro -->
                <VBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false"
                                onAction="#handleEstoque"
                                prefHeight="80.0"
                                prefWidth="250.0"
                                styleClass="login-button"
                                text="ESTOQUE" />

                        <Button mnemonicParsing="false"
                                onAction="#handleClientes"
                                prefHeight="80.0"
                                prefWidth="250.0"
                                styleClass="login-button"
                                text="CLIENTES" />

                        <!-- Novo botão adicionado -->
                        <Button mnemonicParsing="false"
                                onAction="#handleServicos"
                                prefHeight="80.0"
                                prefWidth="250.0"
                                styleClass="login-button"
                                text="SERVIÇOS" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>